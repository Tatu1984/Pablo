###############################################################################
# Pablo — environment variables
#
# Copy to `.env.local` for local development, or set these in your hosting
# platform (Vercel / Fly / Railway / etc.) for deployment.
# `.env.local` is gitignored — never commit real secrets.
###############################################################################

# ────────────────────────────────────────────────────────────────────────────
# Database — required
# ────────────────────────────────────────────────────────────────────────────
# Neon / Postgres connection string. Must include sslmode=require.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require&channel_binding=require

# ────────────────────────────────────────────────────────────────────────────
# Auth — required
# ────────────────────────────────────────────────────────────────────────────
# Signing key for session JWTs. Generate with: openssl rand -base64 32
JWT_SECRET=change_me_32_bytes_base64

# Master key used to encrypt BYO provider API keys at rest (AES-256-GCM).
# Generate with: openssl rand -base64 32
PROVIDER_ENCRYPTION_KEY=change_me_32_bytes_base64

# Public base URL where the Next.js UI is served.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ────────────────────────────────────────────────────────────────────────────
# LLM Gateway — required for live LLM calls
# ────────────────────────────────────────────────────────────────────────────
# Default platform-managed provider. Users can additionally register BYO keys
# through the UI (see /providers/new).
OPENROUTER_API_KEY=sk-or-v1-change_me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional managed-provider fallbacks — leave empty if not used.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ────────────────────────────────────────────────────────────────────────────
# Queue + ephemeral state — required in production
# ────────────────────────────────────────────────────────────────────────────
# Redis (BullMQ) for the async job queue, rate-limiting, and heartbeat state.
REDIS_URL=redis://localhost:6379

# ────────────────────────────────────────────────────────────────────────────
# Object store (trace blobs, large outputs) — recommended in production
# ────────────────────────────────────────────────────────────────────────────
# Any S3-compatible store. Use MinIO locally.
S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
S3_REGION=us-east-1
S3_BUCKET_TRACES=pablo-traces
S3_BUCKET_OUTPUTS=pablo-outputs
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ────────────────────────────────────────────────────────────────────────────
# Billing — Stripe
# ────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_change_me
STRIPE_WEBHOOK_SECRET=whsec_change_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_change_me

# Stripe price IDs per plan (comma-separated is fine if a plan bundles several).
STRIPE_PRICE_STARTER=price_change_me
STRIPE_PRICE_PRO=price_change_me

# ────────────────────────────────────────────────────────────────────────────
# Observability — optional, recommended in production
# ────────────────────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=pablo-web
LOG_LEVEL=info

# ────────────────────────────────────────────────────────────────────────────
# Webhook signing — required if webhooks are enabled
# ────────────────────────────────────────────────────────────────────────────
# Default secret when one is not overridden per webhook.
WEBHOOK_SIGNING_SECRET=change_me

# ────────────────────────────────────────────────────────────────────────────
# Feature flags
# ────────────────────────────────────────────────────────────────────────────
# Comma-separated list of provider types to surface in /providers/new.
ENABLED_PROVIDER_TYPES=openrouter,openai,anthropic,google,bedrock,openai_compatible,ollama

# ────────────────────────────────────────────────────────────────────────────
# Worker-only (for the TS EdgeNest job runner — separate deployment)
# ────────────────────────────────────────────────────────────────────────────
# WORKER_ID=wkr-local-1
# WORKER_CONCURRENCY=4
# WORKER_REGION=iad1
